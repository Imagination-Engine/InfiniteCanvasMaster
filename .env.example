# Imagination Engine - Canonical Environment Blueprint
# This file defines the required environment variables and their security classifications.
# DO NOT place actual secrets in this file. Copy this to `.env` and fill in local values.

# ==============================================================================
# Class A: Sovereign Secrets (High Risk)
# Scope: Must NEVER leave the Cloudflare Worker execution context.
# Access: Only accessible by the backend server.
# ==============================================================================

# Database access
DB_PASSWORD=your_db_password_here

# LLM Provider Keys
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ==============================================================================
# Class B: Integration Tokens (Medium Risk)
# Scope: Used by Server and external MCP instances.
# Access: Bound to specific external systems.
# ==============================================================================

# SaaS Integrations
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
NOTION_API_KEY=secret_your_notion_key
NANOBANANA_API_KEY=your_nanobanana_key
ELEVENLABS_API_KEY=your_elevenlabs_key

# ==============================================================================
# Class C: Safe Configuration (Low Risk)
# Scope: Safe for client-side injection.
# Access: Bundled by Vite into the frontend `apps/web`.
# ==============================================================================

# Vite prefixed variables are exposed to the client
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001
VITE_LIVEBLOCKS_PUBLIC_KEY=pk_live_your_liveblocks_key
